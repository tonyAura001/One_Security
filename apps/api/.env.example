# ── Base de données ──
# En local : Postgres (ex. `postgresql://user@localhost:5432/pilotepme_dev?schema=public`)
# En cible : chaîne de connexion Supabase (pooler 6543 pour l'app, direct 5432 pour migrate)
DATABASE_URL="postgresql://user@localhost:5432/pilotepme_dev?schema=public"
DIRECT_URL="postgresql://user@localhost:5432/pilotepme_dev?schema=public"

# ── Supabase ──
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Secret JWT du projet Supabase (Settings → API) — vérifie les tokens côté API.
SUPABASE_JWT_SECRET="change-me"

# ── App ──
PORT="4000"
NODE_ENV="development"
